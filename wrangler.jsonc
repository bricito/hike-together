{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hike-together",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",

  "alias": {
    "#tanstack-router-entry": "./src/router.tsx",
    "#tanstack-start-entry": "./src/client.tsx",
    "tanstack-start-manifest:v": "./.tanstack/start/manifest.json"
  },

  "vars": {
    "PUBLIC_BASE_URL": "https://blablahike.eu"
  },

  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false
    }
  }
}
